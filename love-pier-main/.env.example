# ── Supabase ───────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose to the browser.
# Used by server actions for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Drizzle) ─────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string → "URI"
# Use the connection pooler (port 6543) string for serverless / Vercel.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# ── Storage ────────────────────────────────────────────────
# Public bucket name that holds menu images (create it in step 2 of SETUP_ADMIN.md)
NEXT_PUBLIC_SUPABASE_MENU_BUCKET=menu-images

# ── LINE ordering / delivery checkout ──────────────────────
# LIFF ID from LINE Developers → your LINE Login channel → LIFF tab
# (format: 2010601364-AbCdEfGh). Leave blank to hide the "Log in with LINE" button.
NEXT_PUBLIC_LIFF_ID=

# Google Apps Script Web App URL that logs LINE customers to a Google Sheet.
# Leave blank to disable. (Client-side, no-cors POST — same as the reference index.html.)
NEXT_PUBLIC_SHEETS_WEBHOOK_URL=

# Shop PromptPay target for the payment QR.
#  - phone number / national ID / tax ID  → leave NEXT_PUBLIC_PROMPTPAY_TYPE blank
#  - company Biller ID (Bill Payment QR)   → set NEXT_PUBLIC_PROMPTPAY_TYPE=biller
NEXT_PUBLIC_PROMPTPAY_ID=
NEXT_PUBLIC_PROMPTPAY_TYPE=
# Fixed Ref1/Ref2/Terminal Label for a Bill Payment QR. Many billers (e.g. SCB
# Mae Manee) reject a dynamic/random Ref1 — they only accept the exact values
# registered to the account. Read a QR decoder against the biller's own
# printed static QR sticker to find the correct values; don't guess.
NEXT_PUBLIC_PROMPTPAY_REF=
NEXT_PUBLIC_PROMPTPAY_REF2=
NEXT_PUBLIC_PROMPTPAY_TERMINAL_LABEL=

# LINE Official Account ID (with the leading @) used for the "send slip" button.
NEXT_PUBLIC_LINE_OA_ID=@lovepier.cafe

# New-order alert to the shop (LINE Messaging API — from the OA's Messaging API channel).
# Leave blank to disable notifications.
LINE_MESSAGING_TOKEN=
# userId or groupId to push the alert to (see ORDER_SETUP.md for how to get it).
LINE_ORDER_NOTIFY_TO=

# Delivery distance check (Google Routes API — driving distance from the shop).
# Leave GOOGLE_MAPS_API_KEY blank to disable the distance check.
GOOGLE_MAPS_API_KEY=
SHOP_LAT=
SHOP_LNG=
DELIVERY_RADIUS_KM=5
