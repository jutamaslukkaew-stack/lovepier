# ── Supabase ───────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose to the browser.
# Used by server actions for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Drizzle) ─────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string → "URI"
# Use the connection pooler (port 6543) string for serverless / Vercel.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# ── Storage ────────────────────────────────────────────────
# Public bucket name that holds menu images (create it in step 2 of SETUP_ADMIN.md)
NEXT_PUBLIC_SUPABASE_MENU_BUCKET=menu-images
